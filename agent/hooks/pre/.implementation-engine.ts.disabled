import type { HookAPI } from "@oh-my-pi/pi-coding-agent/hooks";

/**
 * Implementation Engine Worktree Hook
 * 
 * Forces worktree creation when implementation starts.
 * Intercepts /implement commands and prompts for branch name before the agent starts.
 * Worktree creation runs in BACKGROUND while the agent prepares implementation context.
 * After worktree is ready, switches the main repo to that branch.
 */
export default function (pi: HookAPI) {
  // Track if we've already set up worktree for this session
  let worktreeSetupDone = false;
  let worktreeSetupInProgress = false;
  let currentWorktreePath: string | undefined;
  let currentBranchName: string | undefined;

  // Reset on new session
  pi.on("session_switch", async () => {
    worktreeSetupDone = false;
    worktreeSetupInProgress = false;
    currentWorktreePath = undefined;
    currentBranchName = undefined;
  });

  // Intercept before agent starts to check for /implement
  pi.on("before_agent_start", async (event, ctx) => {
    const prompt = event.prompt?.toLowerCase() ?? "";
    
    // Check if this is an implementation request
    const isImplementationRequest =
      prompt.startsWith("/implement") ||
      prompt.includes("start implementation") ||
      prompt.includes("implement this plan");
    if (!isImplementationRequest || worktreeSetupDone || worktreeSetupInProgress) {
      return;
    }

    if (!ctx.hasUI) {
      // No UI available (print mode), skip
      return;
    }

    // Extract topic from the prompt for suggestions
    const topic = extractTopic(event.prompt ?? "");
    const slug = topicToSlug(topic);

    // Get available branches for base branch selection
    const branches = await getRecentBranches(pi, ctx.cwd);

    // Ask for BASE branch first (what to branch FROM)
    const baseBranch = await ctx.ui.select(
      "Which branch should the worktree be based on?",
      branches
    );

    let finalBaseBranch: string;
    if (!baseBranch) {
      // User cancelled select - let them type their own
      const customBase = await ctx.ui.input(
        "Enter base branch name:",
        "master"
      );
      
      if (!customBase) {
        ctx.ui.notify("Worktree setup cancelled", "warning");
        return;
      }
      
      finalBaseBranch = customBase;
    } else {
      finalBaseBranch = baseBranch;
    }

    // Ask for NEW branch name (what to call the new branch)
    const branchName = await ctx.ui.select(
      `New branch name? (will branch from ${finalBaseBranch})`,
      [
        `feature/${slug}`,
        `fix/${slug}`,
        `impl/${slug}`,
      ]
    );

    let finalBranchName: string;
    
    if (!branchName) {
      // User cancelled select - let them type their own
      const customBranch = await ctx.ui.input(
        "Enter new branch name:",
        `feature/${slug}`
      );
      
      if (!customBranch) {
        ctx.ui.notify("Worktree setup cancelled", "warning");
        return;
      }
      
      finalBranchName = customBranch;
    } else {
      finalBranchName = branchName;
    }

    currentBranchName = finalBranchName;
    worktreeSetupInProgress = true;

    // Show status in footer
    ctx.ui.setStatus("worktree", `⏳ Creating worktree: ${finalBranchName} (from ${finalBaseBranch})...`);

    // Start worktree creation in BACKGROUND (don't await!)
    createWorktreeBackground(pi, ctx, finalBranchName, finalBaseBranch);

    // Inject a placeholder message so the agent knows worktree is being created
    return {
      message: {
        customType: "implement-worktree/pending",
        content: `## Worktree Setup In Progress\n\n- **New Branch:** \`${finalBranchName}\`\n- **Based On:** \`${finalBaseBranch}\`\n- **Status:** Creating in background...\n\nProceed with implementation setup. The worktree path will be provided when ready.`,
        display: true,
        details: {
          branchName: finalBranchName,
          baseBranch: finalBaseBranch,
          status: "pending",
        },
      },
    };
  });

  /**
   * Background worktree creation - runs async, reports back via sendMessage
   */
  async function createWorktreeBackground(
    pi: HookAPI,
    ctx: { cwd: string; ui: { setStatus: (key: string, text: string | undefined) => void; notify: (msg: string, level: "info" | "warning" | "error") => void } },
    branchName: string,
    baseBranch: string
  ) {
    try {
      // Update status
      ctx.ui.setStatus("worktree", `⏳ Creating worktree: ${branchName} (from ${baseBranch})...`);
      
      const result = await createWorktree(pi, ctx.cwd, branchName, baseBranch);
      currentWorktreePath = result.path;
      
      // Now switch the main repo to this branch
      ctx.ui.setStatus("worktree", `⏳ Switching to branch: ${branchName}...`);
      await switchToBranch(pi, ctx.cwd, branchName);
      
      worktreeSetupDone = true;
      worktreeSetupInProgress = false;

      // Clear status and notify
      ctx.ui.setStatus("worktree", undefined);
      ctx.ui.notify(`✓ Worktree ready & switched to ${branchName}`, "info");

      // Inject completion message into conversation
      pi.sendMessage({
        customType: "implement-worktree/ready",
        content: `## ✓ Worktree Ready & Branch Active\n\n- **Branch:** \`${branchName}\` (now checked out)\n- **Based On:** \`${baseBranch}\`\n- **Worktree Path:** \`${currentWorktreePath}\`\n\n**Current session is now on branch \`${branchName}\`.**\n\n**Include this in your implementation kickoff context:**\n\`\`\`bash\n# Implementation will happen on branch: ${branchName}\n# Worktree available at: ${currentWorktreePath}\n\`\`\``,
        display: true,
        details: {
          branchName,
          baseBranch,
          worktreePath: currentWorktreePath,
          status: "ready",
        },
      });
    } catch (error) {
      worktreeSetupInProgress = false;
      const msg = error instanceof Error ? error.message : String(error);
      
      ctx.ui.setStatus("worktree", undefined);
      ctx.ui.notify(`✗ Worktree failed: ${msg}`, "error");

      // Inject error message
      pi.sendMessage({
        customType: "implement-worktree/error",
        content: `## ✗ Worktree Setup Failed\n\n- **Branch:** \`${branchName}\`\n- **Based On:** \`${baseBranch}\`\n- **Error:** ${msg}\n\nYou can retry with \`/worktree ${branchName}\` or continue without a worktree.`,
        display: true,
        details: {
          branchName,
          baseBranch,
          error: msg,
          status: "error",
        },
      });
    }
  }

  // Register /worktree command to check status or create manually
  pi.registerCommand("worktree", {
    description: "Show or create worktree for current session",
    handler: async (args, ctx) => {
      if (worktreeSetupInProgress) {
        ctx.ui.notify(`Worktree creation in progress: ${currentBranchName}`, "info");
        return;
      }

      if (currentWorktreePath) {
        ctx.ui.notify(`Current worktree: ${currentWorktreePath} (${currentBranchName})`, "info");
        return;
      }

      // Parse args: /worktree [new-branch] [base-branch]
      const parts = args.trim().split(/\s+/);
      let branchName = parts[0] || await ctx.ui.input("New branch name:", "feature/");
      if (!branchName) {
        ctx.ui.notify("Cancelled", "info");
        return;
      }

      // Get base branch
      const branches = await getRecentBranches(pi, ctx.cwd);
      let baseBranch = parts[1] || await ctx.ui.select("Base branch?", branches);
      if (!baseBranch) {
        baseBranch = await ctx.ui.input("Enter base branch:", "master");
        if (!baseBranch) {
          ctx.ui.notify("Cancelled", "info");
          return;
        }
      }

      currentBranchName = branchName;
      worktreeSetupInProgress = true;
      ctx.ui.setStatus("worktree", `⏳ Creating worktree: ${branchName} (from ${baseBranch})...`);

      // Run in background
      createWorktreeBackground(pi, ctx, branchName, baseBranch);
    },
  });
}

/**
 * Get recent/common branches for selection
 */
async function getRecentBranches(pi: HookAPI, cwd: string): Promise<string[]> {
  const branches: string[] = [];
  
  // Always include master/main first
  const mainCheck = await pi.exec("git", ["rev-parse", "--verify", "master"], { cwd });
  if (mainCheck.code === 0) {
    branches.push("master");
  }
  
  const mainAltCheck = await pi.exec("git", ["rev-parse", "--verify", "main"], { cwd });
  if (mainAltCheck.code === 0 && !branches.includes("main")) {
    branches.push("main");
  }

  // Get current branch
  const currentResult = await pi.exec("git", ["branch", "--show-current"], { cwd });
  const currentBranch = currentResult.stdout.trim();
  if (currentBranch && !branches.includes(currentBranch)) {
    branches.push(currentBranch);
  }

  // Get recently checked out branches (up to 5 more)
  const recentResult = await pi.exec(
    "git", 
    ["for-each-ref", "--sort=-committerdate", "--count=5", "--format=%(refname:short)", "refs/heads/"],
    { cwd }
  );
  
  if (recentResult.code === 0) {
    const recentBranches = recentResult.stdout.trim().split("\n").filter(Boolean);
    for (const branch of recentBranches) {
      if (!branches.includes(branch)) {
        branches.push(branch);
      }
      if (branches.length >= 5) break;
    }
  }

  return branches.length > 0 ? branches : ["master"];
}

/**
 * Extract the main topic from an implementation prompt
 */
function extractTopic(prompt: string): string {
  // Remove /implement prefix
  let text = prompt.replace(/^\/implement\s*/i, "").trim();
  
  // Remove common filler words
  text = text
    .replace(/^(let'?s?|we should|i want to|please|can you)\s*/i, "")
    .replace(/\s*(implement|create|build|add|make|design|plan)\s*/i, " ")
    .trim();

  // Take first few words as topic
  const words = text.split(/\s+/).slice(0, 3);
  return words.join(" ") || "feature";
}

/**
 * Convert topic to URL-safe slug
 */
function topicToSlug(topic: string): string {
  return topic
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "")
    .slice(0, 30) || "feature";
}

/**
 * Switch the main repo to the specified branch
 */
async function switchToBranch(
  pi: HookAPI,
  cwd: string,
  branchName: string
): Promise<void> {
  // First, check if there are uncommitted changes
  const statusResult = await pi.exec("git", ["status", "--porcelain"], { cwd });
  const hasChanges = statusResult.stdout.trim().length > 0;

  if (hasChanges) {
    // Stash changes before switching
    await pi.exec("git", ["stash", "push", "-m", `auto-stash before switching to ${branchName}`], { cwd });
  }

  // Switch to the branch
  const checkoutResult = await pi.exec("git", ["checkout", branchName], { cwd });
  
  if (checkoutResult.code !== 0) {
    // If stashed, try to restore
    if (hasChanges) {
      await pi.exec("git", ["stash", "pop"], { cwd });
    }
    throw new Error(`Failed to checkout branch: ${checkoutResult.stderr}`);
  }

  // If we stashed, pop the stash
  if (hasChanges) {
    await pi.exec("git", ["stash", "pop"], { cwd });
  }
}

/**
 * Create a git worktree
 */
async function createWorktree(
  pi: HookAPI,
  cwd: string,
  branchName: string,
  baseBranch: string
): Promise<{ path: string }> {
  // Determine worktree directory
  const worktreeDir = `${cwd}/.worktrees`;
  const safeName = branchName.replace(/[^a-zA-Z0-9-]/g, "-");
  const worktreePath = `${worktreeDir}/${safeName}`;

  // Create worktrees directory if needed
  await pi.exec("mkdir", ["-p", worktreeDir]);

  // Add to .gitignore if not present
  const gitignoreResult = await pi.exec("grep", ["-q", "^.worktrees", ".gitignore"], { cwd });
  if (gitignoreResult.code !== 0) {
    await pi.exec("sh", ["-c", "echo '.worktrees/' >> .gitignore"], { cwd });
  }

  // Check if branch already exists
  const branchCheck = await pi.exec("git", ["rev-parse", "--verify", branchName], { cwd });
  
  if (branchCheck.code === 0) {
    // Branch exists - check if worktree already exists
    const worktreeExists = await pi.exec("test", ["-d", worktreePath]);
    if (worktreeExists.code === 0) {
      // Worktree already exists, just return it
      return { path: worktreePath };
    }
    
    // Branch exists but no worktree, create worktree from it
    const result = await pi.exec("git", ["worktree", "add", worktreePath, branchName], { cwd });
    if (result.code !== 0) {
      throw new Error(result.stderr || "Failed to create worktree");
    }
  } else {
    // Create new branch from base branch with worktree
    const result = await pi.exec("git", ["worktree", "add", "-b", branchName, worktreePath, baseBranch], { cwd });
    if (result.code !== 0) {
      throw new Error(result.stderr || "Failed to create worktree");
    }
  }

  // Detect and run package manager setup
  await runPackageSetup(pi, worktreePath);

  return { path: worktreePath };
}

/**
 * Detect project type and run appropriate setup
 */
async function runPackageSetup(pi: HookAPI, path: string): Promise<void> {
  // Check for various package managers/project types
  const checks = [
    { file: "bun.lockb", cmd: ["bun", "install"] },
    { file: "pnpm-lock.yaml", cmd: ["pnpm", "install"] },
    { file: "yarn.lock", cmd: ["yarn", "install"] },
    { file: "package-lock.json", cmd: ["npm", "install"] },
    { file: "package.json", cmd: ["npm", "install"] }, // fallback for node projects
    { file: "Cargo.toml", cmd: ["cargo", "fetch"] },
    { file: "pyproject.toml", cmd: ["uv", "sync"] },
    { file: "requirements.txt", cmd: ["pip", "install", "-r", "requirements.txt"] },
    { file: "go.mod", cmd: ["go", "mod", "download"] },
  ];

  for (const { file, cmd } of checks) {
    const check = await pi.exec("test", ["-f", `${path}/${file}`]);
    if (check.code === 0) {
      const [program, ...args] = cmd;
      await pi.exec(program, args, { cwd: path, timeout: 120000 });
      return;
    }
  }
}
