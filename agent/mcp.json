{
  "mcpServers": {
    "augment": {
      "type": "stdio",
      "command": "auggie",
      "args": [
        "--mcp",
        "--mcp-auto-workspace"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "better-context": {
      "type": "http",
      "url": "https://btca.dev/api/mcp",
      "enabled": true,
      "timeout": 120000,
      "headers": {
        "Authorization": "Bearer ${BTCA_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "grafana": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-grafana"
      ],
      "env": {
        "GRAFANA_URL": "!bash /home/colin/devpod-repos/DefaceRoot/oh-my-pi/agent/scripts/resolve-monocle-grafana-url.sh",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "!bash /home/colin/devpod-repos/DefaceRoot/oh-my-pi/agent/scripts/resolve-monocle-grafana-token.sh"
      },
      "enabled": true,
      "timeout": 120000
    }
  }
}
