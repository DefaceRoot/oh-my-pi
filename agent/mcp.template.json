{
  "mcpServers": {
    "augment": {
      "type": "stdio",
      "command": "auggie",
      "args": [
        "--mcp",
        "--mcp-auto-workspace"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "better-context": {
      "type": "http",
      "url": "https://btca.dev/api/mcp",
      "enabled": true,
      "timeout": 120000,
      "headers": {
        "Authorization": "Bearer <REPLACE_WITH_YOUR_BTCA_KEY>"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated"
      ],
      "enabled": true,
      "timeout": 120000
    }
  }
}
